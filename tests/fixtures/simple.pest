WHITESPACE = _{ " " | "\t" | newline }
COMMENT = _{ line_comment }
newline = _{ "\n" | "\r\n" }
line_comment = _{ "//" ~ (!newline ~ ANY)* }

main = { SOI ~ item ~ ("," ~ item)* ~ EOI }
item = { ident ~ "=" ~ number }
ident = @{ ("_" | ASCII_ALPHA) ~ ("_" | ASCII_ALPHANUMERIC)* }
number = @{ ASCII_DIGIT+ }
