{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "test -f pkg/web_bg.wasm",
  "installCommand": "echo 'Built in GitHub Actions'",
  "outputDirectory": ".",
  "framework": null,
  "ignoreCommand": "exit 0",
  "headers": [
    {
      "source": "/(.*)\\.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    }
  ]
}
